{
  "navigationFallback": {
    "document": "/index.html",
    "exclude": ["/images/*.{png,jpg,gif,ico,webp}", "/css/*", "/_next/*", "/api/*", "/*.{ico,png,json,txt,xml}"]
  },
  "routes": [
    {
      "route": "/_next/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/static/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    }
  ],
  "responseOverrides": {
    "404": {
      "document": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}